{
    "name": "atwx/silverstripe-headless-pdf",
    "description": "Headless Chrome PDF generation for SilverStripe",
    "type": "silverstripe-vendormodule",
    "keywords": [
        "silverstripe",
        "pdf",
        "headless",
        "chrome"
    ],
    "license": "BSD-3-Clause",
    "require": {
        "php": "^8.3",
        "silverstripe/framework": "^6.0",
        "chrome-php/chrome": "^1.15"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "squizlabs/php_codesniffer": "^4.0",
        "silverstripe/standards": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "ATWX\\HeadlessPDF\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ATWX\\HeadlessPDF\\Tests\\": "tests/php/"
        }
    },
    "extra": {
        "expose": []
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
